# Stage 1: Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Pre-create the data directory and set permissions for distroless nonroot user (uid: 65532)
RUN mkdir -p data && chown -R 65532:65532 data

COPY package*.json ./
RUN npm ci --omit=dev

COPY src/ ./src/

# Stage 2: Minimal runtime stage using Google Distroless Node.js
FROM gcr.io/distroless/nodejs20-debian12 AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV DB_PATH=/app/data/pchclk.db

# Copy pre-created data directory and source files from builder with correct nonroot ownership
COPY --from=builder --chown=nonroot:nonroot /app/data ./data
COPY --from=builder --chown=nonroot:nonroot /app/node_modules ./node_modules
COPY --from=builder --chown=nonroot:nonroot /app/package*.json ./
COPY --from=builder --chown=nonroot:nonroot /app/src ./src

# Run as non-privileged system user (distroless nonroot user is uid 65532)
USER nonroot

EXPOSE 3000

# Automated healthcheck using native Node.js fetch inside distroless (no shell format)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD ["/nodejs/bin/node", "-e", "fetch('http://localhost:3000/api/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"]

CMD ["src/server.js"]
