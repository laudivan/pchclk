# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# In containers, store under /app/data/
DB_PATH=./data/pchclk.db

# Authentication / Security
JWT_SECRET=super-secret-rotation-key-change-me-in-production

# Punch Clock Configurations
# Day of month the frequency period starts (e.g. 20 for Jun 20 to Jul 19)
GLOBAL_START_DAY=20
