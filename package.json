{
  "name": "pchclk",
  "version": "1.0.0",
  "description": "Unified PchClk Punch Clock Portal",
  "type": "module",
  "scripts": {
    "dev:backend": "node src/server.js",
    "dev:frontend": "vite",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vite build",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "test": "node --test test/**/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.1.2",
    "vite": "^8.1.1"
  }
